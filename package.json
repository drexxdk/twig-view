{
  "name": "twig-view",
  "version": "0.1.3",
  "description": "Accessible React tree view component for nested data, keyboard navigation, async branches, and customizable connectors",
  "license": "MIT",
  "homepage": "https://drexxdk.github.io/twig-view/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drexxdk/twig-view.git"
  },
  "bugs": {
    "url": "https://github.com/drexxdk/twig-view/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "react-component",
    "tree",
    "tree-view",
    "treeview",
    "accessible",
    "accessibility",
    "a11y",
    "keyboard-navigation",
    "hierarchy",
    "outline",
    "nested-data",
    "expandable",
    "wai-aria",
    "ui-component"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "build": "node ./scripts/clean-dist.mjs && tsc -p tsconfig.build.json && node ./scripts/copy-assets.mjs",
    "build:demo": "vite build --config vite.config.ts",
    "lint": "eslint .",
    "preview": "vite preview --config vite.config.ts",
    "prepack": "npm run build",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^7.0.0",
    "vitest": "^3.1.2"
  }
}
